---
import logoColor from '../assets/SVG/Voxye_Color.svg';

const navLinks = [
  { label: 'Funcionalidades', href: '#funcionalidades' },
  { label: 'Proceso', href: '#proceso' },
  { label: 'Beneficios', href: '#beneficios' },
  { label: 'FAQ', href: '#faq' },
];
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-[background-color,box-shadow] duration-300"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="#" class="flex items-center group">
        <img src={logoColor.src} alt="Voxye" class="h-8 w-auto transition-transform group-hover:scale-105" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-white/70 hover:text-white transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#contacto"
          class="bg-accent-gradient hover:opacity-90 text-primary font-semibold text-sm px-5 py-2.5 rounded-lg transition-opacity"
        >
          Solicitar Demo
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-white p-2"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Nav -->
    <nav
      id="mobile-menu"
      class="md:hidden hidden pb-4"
    >
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block py-2 text-sm font-medium text-white/70 hover:text-white transition-colors mobile-nav-link"
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contacto"
        class="mt-3 block text-center bg-accent-gradient hover:opacity-90 text-primary font-semibold text-sm px-5 py-2.5 rounded-lg transition-opacity mobile-nav-link"
      >
        Solicitar Demo
      </a>
    </nav>
  </div>
</header>
