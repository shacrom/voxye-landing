---
const features = [
  {
    code: 'MOD-01',
    title: 'Presupuestos',
    desc: 'Editor modular con vista previa PDF en tiempo real. Estados, duplicado en un clic y firma digital del cliente.',
  },
  {
    code: 'MOD-02',
    title: 'Contratos',
    desc: 'Generados desde el presupuesto aceptado, con copia inmutable del contenido y todo el historial vinculado.',
  },
  {
    code: 'MOD-03',
    title: 'Facturas proforma',
    desc: 'Proformas a cuenta y finales con deducción automática de anticipos. IVA configurable y PDF generado al instante.',
  },
  {
    code: 'MOD-04',
    title: 'Email integrado',
    desc: 'Envía presupuestos, proformas y pedidos por email con el PDF adjunto, y sigue su estado de entrega.',
  },
  {
    code: 'MOD-05',
    title: 'Clientes y productos',
    desc: 'Fichas de clientes y catálogo de productos con precios, búsqueda rápida e importación desde Excel.',
  },
  {
    code: 'MOD-06',
    title: 'Pedidos a proveedores',
    desc: 'Creados desde el contrato, con PDF imprimible, envío por email y seguimiento de estados.',
  },
  {
    code: 'MOD-07',
    title: 'Incidencias',
    desc: 'Prioridades, asignación a proveedores, comentarios internos y adjuntos. Nada se queda sin resolver.',
  },
  {
    code: 'MOD-08',
    title: 'Subcontrataciones',
    desc: 'Solicitudes de oferta documentadas, con seguimiento de estado, emails y adjuntos por conversación.',
  },
  {
    code: 'MOD-09',
    title: 'Hojas de carga',
    desc: 'Documento de recogida y entrega de materiales, listo para imprimir o enviar por email.',
  },
  {
    code: 'MOD-10',
    title: 'Analítica de negocio',
    desc: 'Conversión presupuesto→contrato, ingresos mensuales, top clientes y más de 25 indicadores.',
  },
  {
    code: 'MOD-11',
    title: 'Multi-tienda',
    desc: 'Una empresa, varias tiendas o almacenes. Datos aislados, roles y permisos por usuario.',
  },
  {
    code: 'MOD-12',
    title: 'Numeración y auditoría',
    desc: 'Series de documentos a tu medida ({empresa}-{año}-{nº}) y registro de quién hizo qué y cuándo.',
  },
];
---

<section id="funcionalidades" class="py-24 lg:py-32 bg-surface-alt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 fade-up">
      <p class="doc-label text-accent mb-4">Índice de módulos</p>
      <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-[2.75rem] text-text-primary mb-4 leading-tight">
        Todo el ciclo del proyecto, documentado
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl">
        Doce módulos que cubren el día a día de una empresa de reformas: de la primera
        visita al cliente hasta la proforma final, pasando por proveedores e incidencias.
      </p>
    </div>

    <!-- Features Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 stagger-children">
      {features.map((feature) => (
        <div class="doc-card group p-6 hover:border-accent/40 hover:-translate-y-0.5 transition-[border-color,transform,box-shadow] duration-300 hover:shadow-lg fade-up">
          <div class="flex items-center justify-between mb-4">
            <span class="font-mono text-xs text-text-secondary group-hover:text-accent transition-colors">{feature.code}</span>
            <span class="perforation w-12"></span>
          </div>
          <h3 class="font-display font-semibold text-lg text-text-primary mb-2">{feature.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{feature.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
