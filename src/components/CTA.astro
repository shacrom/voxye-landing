---
import { CONTACT_PHONE } from '../consts';
---

<section id="contacto" class="relative py-24 lg:py-32 bg-primary overflow-hidden">
  <div class="hero-ambient absolute inset-0"></div>
  <div class="blueprint-grid absolute inset-0 opacity-40"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
    <span class="stamp inline-block text-sm text-accent-light mb-8">Demo gratuita</span>

    <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-text-inverse mb-6 leading-tight">
      ¿Vemos cómo encaja Voxye<br class="hidden sm:block" /> con tu forma de trabajar?
    </h2>
    <p class="text-white/60 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
      Solicita una demo y recorremos contigo el ciclo completo —presupuesto, contrato,
      pedidos y proforma— con ejemplos de tu propio negocio.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href="/contacto"
        class="bg-accent-gradient hover:opacity-90 text-primary font-semibold px-8 py-3.5 rounded-lg transition-opacity text-base"
      >
        Solicitar demo
      </a>
      <a
        href={`tel:${CONTACT_PHONE.replace(/\s/g, '')}`}
        class="border border-white/20 hover:border-white/40 text-white font-semibold px-8 py-3.5 rounded-lg transition-colors text-base"
      >
        Llamar ahora
      </a>
    </div>

    <!-- Direct contact -->
    <p class="text-white/40 text-sm">
      También puedes llamarnos:
      <a href={`tel:${CONTACT_PHONE.replace(/\s/g, '')}`} class="text-accent-light hover:text-white transition-colors">{CONTACT_PHONE}</a>
    </p>
  </div>
</section>
