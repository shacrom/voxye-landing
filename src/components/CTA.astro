---
import { CONTACT_PHONE } from '../consts';
---

<section id="contacto" class="relative py-24 lg:py-32 bg-primary overflow-hidden">
  <div class="hero-ambient absolute inset-0"></div>
  <div class="blueprint-grid absolute inset-0 opacity-40"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center fade-up">
    <span class="stamp inline-block text-sm text-accent-light mb-8">Demo gratuita</span>

    <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-text-inverse mb-6 leading-tight">
      ¿Vemos cómo encaja Voxye<br class="hidden sm:block" /> con tu forma de trabajar?
    </h2>
    <p class="text-white/60 text-lg max-w-2xl mx-auto mb-10 leading-relaxed">
      Solicita una demo y recorremos contigo el ciclo completo —presupuesto, contrato,
      pedidos y proforma— con ejemplos de tu propio negocio.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
      <a
        href="/contacto"
        class="bg-accent-gradient hover:opacity-90 text-primary font-semibold px-8 py-3.5 rounded-lg transition-opacity text-base"
      >
        Solicitar demo
      </a>
      <a
        href={`https://wa.me/${CONTACT_PHONE.replace(/\D/g, '')}`}
        class="inline-flex items-center gap-2 border border-white/20 hover:border-white/40 text-white font-semibold px-8 py-3.5 rounded-lg transition-colors text-base"
      >
        <svg class="w-5 h-5 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.52 3.48A11.85 11.85 0 0 0 12.07 0C5.5 0 .16 5.34.16 11.91c0 2.1.55 4.16 1.6 5.97L0 24l6.28-1.65a11.9 11.9 0 0 0 5.79 1.48h.01c6.57 0 11.91-5.34 11.91-11.91 0-3.18-1.24-6.17-3.47-8.44ZM12.08 21.82h-.01a9.88 9.88 0 0 1-5.04-1.38l-.36-.21-3.73.98 1-3.64-.23-.37a9.86 9.86 0 0 1-1.51-5.29c0-5.46 4.44-9.9 9.9-9.9a9.82 9.82 0 0 1 7 2.9 9.84 9.84 0 0 1 2.9 7c-.01 5.46-4.45 9.91-9.92 9.91Zm5.43-7.42c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.97-.94 1.17-.17.2-.35.22-.65.07-.3-.15-1.25-.46-2.38-1.47-.88-.78-1.47-1.75-1.64-2.05-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.07-.15-.67-1.61-.92-2.2-.24-.58-.49-.5-.67-.51h-.57c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48s1.07 2.88 1.22 3.08c.15.2 2.1 3.2 5.08 4.49.71.31 1.26.49 1.69.63.71.23 1.36.19 1.87.12.57-.08 1.76-.72 2.01-1.42.25-.7.25-1.3.17-1.42-.07-.13-.27-.2-.57-.35Z" />
        </svg>
        Hablar ahora
      </a>
    </div>

    <!-- Direct contact -->
    <p class="text-white/40 text-sm">
      También puedes escribirnos por WhatsApp:
      <a href={`https://wa.me/${CONTACT_PHONE.replace(/\D/g, '')}`} class="text-accent-light hover:text-white transition-colors">{CONTACT_PHONE}</a>
    </p>
  </div>
</section>
