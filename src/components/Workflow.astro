---
const steps = [
  {
    number: '01',
    title: 'Presupuesto',
    desc: 'Crea presupuestos profesionales con vista previa PDF en tiempo real. Añade partidas, materiales y mano de obra en un editor modular.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9.75a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" />`,
  },
  {
    number: '02',
    title: 'Contrato',
    desc: 'Convierte presupuestos aprobados en contratos digitales con un clic. Toda la información se transfiere automáticamente.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />`,
  },
  {
    number: '03',
    title: 'Ejecución',
    desc: 'Gestiona pedidos a proveedores, controla incidencias y coordina subcontrataciones durante la obra.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17l-5.58-3.65V8.16l5.58 3.65m0 3.36l5.58-3.65V8.16l-5.58 3.65M12 2.25l8.09 5.29v8.92L12 21.75l-8.09-5.29V7.54L12 2.25z" />`,
  },
  {
    number: '04',
    title: 'Facturación',
    desc: 'Genera facturas a cuenta, rectificativas y finales. Control total del flujo económico de cada proyecto.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />`,
  },
];
---

<section id="proceso" class="py-24 lg:py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 fade-up">
      <span class="text-accent font-semibold text-sm uppercase tracking-wider">Proceso de trabajo</span>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl tracking-tight text-text-primary mt-3 mb-4">
        Del presupuesto a la factura, sin fricciones
      </h2>
      <p class="text-text-secondary text-lg">
        Un flujo de trabajo diseñado para el día a día de las empresas de reformas.
      </p>
    </div>

    <!-- Timeline -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, i) => (
        <div class="relative fade-up">
          {/* Connector line (hidden on last item and mobile) */}
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-10 left-full w-full h-px bg-gradient-to-r from-accent/40 to-transparent z-0"></div>
          )}

          <div class="relative bg-surface border border-gray-100 rounded-xl p-6 hover:border-accent/30 hover:shadow-lg transition-[border-color,box-shadow] duration-300">
            {/* Step number */}
            <span class="text-accent/20 font-heading font-extrabold text-5xl absolute top-4 right-4 select-none">{step.number}</span>

            {/* Icon */}
            <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={step.icon} />
              </svg>
            </div>

            <h3 class="font-heading font-semibold text-xl text-text-primary mb-2">{step.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
