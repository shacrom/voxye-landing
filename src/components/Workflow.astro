---
const steps = [
  {
    number: '01',
    title: 'Presupuesto',
    desc: 'Crea el presupuesto en el editor modular con vista previa PDF en tiempo real y envíaselo al cliente por email.',
    tag: 'VX-2026-0142',
  },
  {
    number: '02',
    title: 'Contrato',
    desc: 'El presupuesto aceptado se convierte en contrato con un clic. El contenido queda congelado y vinculado al original.',
    tag: 'CON-2026-0089',
  },
  {
    number: '03',
    title: 'Seguimiento',
    desc: 'Pedidos a proveedores, hojas de carga, incidencias y subcontrataciones, todos colgando del mismo contrato.',
    tag: 'PED · INC · SUB',
  },
  {
    number: '04',
    title: 'Proforma',
    desc: 'Proformas a cuenta durante el proyecto y proforma final con los anticipos deducidos automáticamente.',
    tag: 'PF-2026-0067',
  },
  {
    number: '05',
    title: 'Análisis',
    desc: 'Sigue cuántos presupuestos acaban en contrato, los ingresos estimados y el estado de cada proyecto en el panel de control.',
    tag: '25+ indicadores',
  },
];
---

<section id="proceso" class="py-24 lg:py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 fade-up">
      <p class="doc-label text-accent mb-4">Proceso de trabajo</p>
      <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-[2.75rem] text-text-primary mb-4 leading-tight">
        Cinco pasos, un solo expediente
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl">
        Cada paso genera su documento numerado y queda vinculado al anterior.
        Si dentro de un año necesitas saber qué pasó en un proyecto, está todo ahí.
      </p>
    </div>

    <!-- Timeline -->
    <div id="workflow-timeline" class="relative">
      <!-- Hilo de trazabilidad: escritorio (horizontal, detrás de las tarjetas) -->
      <svg class="thread-desktop hidden lg:block absolute top-9 left-0 w-full h-4 overflow-visible" viewBox="0 0 1000 16" preserveAspectRatio="none" aria-hidden="true">
        <path
          id="thread-path-desktop"
          d="M 10 8 C 150 8, 150 8, 260 8 S 370 8, 480 8 S 590 8, 700 8 S 810 8, 990 8"
          stroke-width="2"
          fill="none"
        />
      </svg>

      <!-- Hilo de trazabilidad: móvil (vertical, borde izquierdo) -->
      <div class="thread-mobile lg:hidden absolute top-2 bottom-2 left-[1.15rem] w-px bg-line" aria-hidden="true">
        <div class="thread-mobile-fill absolute top-0 left-0 w-full bg-accent origin-top"></div>
      </div>

      <div class="relative grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 lg:gap-4 stagger-children pl-10 lg:pl-0">
        {steps.map((step) => (
          <div class="workflow-step relative fade-up" data-step>
            <div class="relative h-full flex flex-col doc-card p-5 transition-[border-color,transform,box-shadow] duration-300 hover:-translate-y-1 hover:shadow-lg">
              <span class="font-display font-extrabold text-4xl text-accent/20 select-none" aria-hidden="true">{step.number}</span>
              <h3 class="font-display font-semibold text-xl text-text-primary mt-2 mb-2">{step.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-4">{step.desc}</p>
              <span class="step-tag font-mono text-[0.65rem] uppercase tracking-wider text-text-secondary border border-line rounded px-2 py-1 inline-block self-start mt-auto transition-colors duration-300">
                {step.tag}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* The thread draws itself once the section enters the viewport; JS kicks off the sequence */
  #thread-path-desktop {
    stroke: var(--color-accent);
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    transition: stroke-dashoffset 2.8s ease-in-out;
  }

  .thread-mobile-fill {
    height: 0%;
    transition: height 2.8s ease-in-out;
  }

  /* Estado activado: la tarjeta y su chip quedan marcados por el hilo */
  .workflow-step.step-active .doc-card {
    border-color: var(--color-accent);
  }

  .workflow-step.step-active .step-tag {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-text-inverse);
  }

  @media (prefers-reduced-motion: reduce) {
    #thread-path-desktop {
      stroke-dashoffset: 0;
    }

    .thread-mobile-fill {
      height: 100%;
    }
  }
</style>

<script>
  // Traceability thread: once the section enters the viewport, the thread draws
  // itself and the steps complete one after another.
  function initWorkflowThread() {
    const section = document.getElementById('workflow-timeline');
    if (!section) return;

    const desktopPath = document.getElementById('thread-path-desktop') as SVGPathElement | null;
    const mobileFill = section.querySelector<HTMLElement>('.thread-mobile-fill');
    const steps = Array.from(section.querySelectorAll<HTMLElement>('[data-step]'));

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      steps.forEach((step) => step.classList.add('step-active'));
      return;
    }

    const pathLength = desktopPath ? desktopPath.getTotalLength() : 0;
    if (desktopPath) {
      desktopPath.style.strokeDasharray = `${pathLength}`;
      desktopPath.style.strokeDashoffset = `${pathLength}`;
    }

    const STEP_STAGGER_MS = 600;
    const FIRST_STEP_DELAY_MS = 200;
    let pendingTimeouts: number[] = [];

    function playSequence() {
      if (desktopPath) {
        desktopPath.style.strokeDashoffset = '0';
      }
      if (mobileFill) {
        mobileFill.style.height = '100%';
      }
      steps.forEach((step, i) => {
        pendingTimeouts.push(
          window.setTimeout(() => step.classList.add('step-active'), FIRST_STEP_DELAY_MS + i * STEP_STAGGER_MS)
        );
      });
    }

    // Snap back to the initial state without animating, so the next entrance replays cleanly
    function resetSequence() {
      pendingTimeouts.forEach((id) => clearTimeout(id));
      pendingTimeouts = [];
      steps.forEach((step) => step.classList.remove('step-active'));

      if (desktopPath) {
        desktopPath.style.transition = 'none';
        desktopPath.style.strokeDashoffset = `${pathLength}`;
        void desktopPath.getBoundingClientRect();
        desktopPath.style.transition = '';
      }
      if (mobileFill) {
        mobileFill.style.transition = 'none';
        mobileFill.style.height = '0%';
        void mobileFill.getBoundingClientRect();
        mobileFill.style.transition = '';
      }
    }

    // Play once ~35% of the section is visible; reset only after it fully leaves
    // the viewport so the snap back is never seen.
    let played = false;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.intersectionRatio >= 0.35 && !played) {
            played = true;
            playSequence();
          } else if (!entry.isIntersecting && played) {
            played = false;
            resetSequence();
          }
        });
      },
      { threshold: [0, 0.35] }
    );

    observer.observe(section);
  }

  initWorkflowThread();
</script>
