---
const steps = [
  {
    number: '01',
    title: 'Presupuesto',
    desc: 'Crea el presupuesto en el editor modular con vista previa PDF en tiempo real. El cliente lo firma digitalmente.',
    tag: 'VX-2026-0142',
  },
  {
    number: '02',
    title: 'Contrato',
    desc: 'El presupuesto aceptado se convierte en contrato con un clic. El contenido queda congelado y vinculado al original.',
    tag: 'CON-2026-0089',
  },
  {
    number: '03',
    title: 'Seguimiento',
    desc: 'Pedidos a proveedores, hojas de carga, incidencias y subcontrataciones, todos colgando del mismo contrato.',
    tag: 'PED · INC · SUB',
  },
  {
    number: '04',
    title: 'Proforma',
    desc: 'Proformas a cuenta durante el proyecto y proforma final con los anticipos deducidos automáticamente.',
    tag: 'PF-2026-0067',
  },
  {
    number: '05',
    title: 'Análisis',
    desc: 'Sigue la conversión de presupuestos, los ingresos y el estado de cada proyecto en el dashboard.',
    tag: '25+ KPIs',
  },
];
---

<section id="proceso" class="py-24 lg:py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-3xl mb-16 fade-up">
      <p class="doc-label text-accent mb-4">Proceso de trabajo</p>
      <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-[2.75rem] text-text-primary mb-4 leading-tight">
        Cinco pasos, un solo expediente
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl">
        Cada paso genera su documento numerado y queda vinculado al anterior.
        Si dentro de un año necesitas saber qué pasó en un proyecto, está todo ahí.
      </p>
    </div>

    <!-- Timeline -->
    <div id="workflow-timeline" class="relative">
      <!-- Hilo de trazabilidad: escritorio (horizontal, detrás de las tarjetas) -->
      <svg class="thread-desktop hidden lg:block absolute top-9 left-0 w-full h-4 overflow-visible" viewBox="0 0 1000 16" preserveAspectRatio="none" aria-hidden="true">
        <path
          id="thread-path-desktop"
          d="M 10 8 C 150 8, 150 8, 260 8 S 370 8, 480 8 S 590 8, 700 8 S 810 8, 990 8"
          stroke-width="2"
          fill="none"
        />
      </svg>

      <!-- Hilo de trazabilidad: móvil (vertical, borde izquierdo) -->
      <div class="thread-mobile lg:hidden absolute top-2 bottom-2 left-[1.15rem] w-px bg-line" aria-hidden="true">
        <div class="thread-mobile-fill absolute top-0 left-0 w-full bg-accent origin-top"></div>
      </div>

      <div class="relative grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 lg:gap-4 stagger-children pl-10 lg:pl-0">
        {steps.map((step) => (
          <div class="workflow-step relative fade-up" data-step>
            <div class="relative h-full doc-card p-5 transition-[border-color,transform,box-shadow] duration-300 hover:-translate-y-1 hover:shadow-lg">
              <span class="font-display font-extrabold text-4xl text-accent/20 select-none" aria-hidden="true">{step.number}</span>
              <h3 class="font-display font-semibold text-xl text-text-primary mt-2 mb-2">{step.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed mb-4">{step.desc}</p>
              <span class="step-tag font-mono text-[0.65rem] uppercase tracking-wider text-text-secondary border border-line rounded px-2 py-1 inline-block transition-colors duration-300">
                {step.tag}
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* El hilo se dibuja según el progreso de scroll de la sección; el activate-* JS controla el offset */
  #thread-path-desktop {
    stroke: var(--color-accent);
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
  }

  .thread-mobile-fill {
    height: 0%;
  }

  /* Estado activado: la tarjeta y su chip quedan marcados por el hilo */
  .workflow-step.step-active .doc-card {
    border-color: var(--color-accent);
  }

  .workflow-step.step-active .step-tag {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-text-inverse);
  }

  @media (prefers-reduced-motion: reduce) {
    #thread-path-desktop {
      stroke-dashoffset: 0;
    }

    .thread-mobile-fill {
      height: 100%;
    }
  }
</style>

<script>
  // Hilo de trazabilidad: se dibuja según el scroll de la sección y activa cada paso a su paso
  function initWorkflowThread() {
    const section = document.getElementById('workflow-timeline');
    if (!section) return;

    const desktopPath = document.getElementById('thread-path-desktop') as SVGPathElement | null;
    const mobileFill = section.querySelector<HTMLElement>('.thread-mobile-fill');
    const steps = Array.from(section.querySelectorAll<HTMLElement>('[data-step]'));

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      steps.forEach((step) => step.classList.add('step-active'));
      return;
    }

    const pathLength = desktopPath ? desktopPath.getTotalLength() : 0;
    if (desktopPath) {
      desktopPath.style.strokeDasharray = `${pathLength}`;
      desktopPath.style.strokeDashoffset = `${pathLength}`;
    }

    let ticking = false;

    function updateThread() {
      ticking = false;
      const rect = section!.getBoundingClientRect();
      const viewportH = window.innerHeight;

      // Progreso 0 -> 1 según el recorrido de la sección por el viewport
      const total = rect.height + viewportH;
      const traveled = viewportH - rect.top;
      const progress = Math.min(1, Math.max(0, traveled / total));

      if (desktopPath && pathLength) {
        desktopPath.style.strokeDashoffset = `${pathLength * (1 - progress)}`;
      }

      if (mobileFill) {
        mobileFill.style.height = `${progress * 100}%`;
      }

      steps.forEach((step, i) => {
        const stepThreshold = (i + 0.5) / steps.length;
        if (progress >= stepThreshold) {
          step.classList.add('step-active');
        }
      });
    }

    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(updateThread);
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    updateThread();
  }

  initWorkflowThread();
</script>
