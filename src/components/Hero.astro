---

---

<section class="relative min-h-screen flex items-center bg-primary overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(212,168,83,0.08)_0%,_transparent_70%)]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 rounded-full px-4 py-1.5 mb-8">
      <span class="w-2 h-2 bg-accent rounded-full"></span>
      <span class="text-sm font-medium text-white/80">ERP Especializado en Reformas</span>
    </div>

    <!-- Heading -->
    <h1 class="font-heading font-extrabold text-4xl sm:text-5xl lg:text-6xl xl:text-7xl text-text-inverse leading-tight max-w-4xl mx-auto mb-6">
      Digitaliza tu empresa de reformas con
      <span class="text-accent"> Voxye</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-lg sm:text-xl text-white/60 max-w-2xl mx-auto mb-10 leading-relaxed">
      Gestiona presupuestos, contratos, facturas y pedidos desde una sola plataforma.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#contacto"
        class="bg-accent hover:bg-accent-light text-primary font-semibold px-8 py-3.5 rounded-lg transition-colors text-base"
      >
        Solicitar Demo Gratuita
      </a>
      <a
        href="#funcionalidades"
        class="border border-white/20 hover:border-white/40 text-white font-semibold px-8 py-3.5 rounded-lg transition-colors text-base"
      >
        Ver Funcionalidades
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
