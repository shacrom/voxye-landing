---
const testimonials = [
  {
    quote: 'Desde que usamos Voxye, hemos reducido el tiempo de creacion de presupuestos a la mitad. La vista previa PDF es una maravilla.',
    name: 'Carlos Martinez',
    role: 'Director, Reformas Martinez',
  },
  {
    quote: 'El control de incidencias y la gestion de subcontratistas nos ha dado una visibilidad que antes no teniamos. Muy recomendable.',
    name: 'Ana Lopez',
    role: 'Gerente, Cocinas del Sur',
  },
  {
    quote: 'La facturacion integrada y el dashboard nos permiten saber en todo momento como va el negocio. Ha sido un cambio total.',
    name: 'Miguel Fernandez',
    role: 'CEO, Grupo Reformas Integrales',
  },
];
---

<section class="py-24 lg:py-32 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 fade-up">
      <span class="text-accent font-semibold text-sm uppercase tracking-wider">Testimonios</span>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl tracking-tight text-text-primary mt-3 mb-4">
        Lo que dicen nuestros clientes
      </h2>
    </div>

    <!-- Testimonials Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
      {testimonials.map((t) => (
        <div class="bg-surface-alt rounded-xl p-8 border border-gray-100 fade-up">
          {/* Stars */}
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-accent" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          {/* Quote */}
          <blockquote class="text-text-primary leading-relaxed mb-6">"{t.quote}"</blockquote>

          {/* Author */}
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-accent/10 rounded-full flex items-center justify-center">
              <span class="font-heading font-bold text-accent text-sm">{t.name[0]}</span>
            </div>
            <div>
              <p class="font-semibold text-sm text-text-primary">{t.name}</p>
              <p class="text-xs text-text-secondary">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
