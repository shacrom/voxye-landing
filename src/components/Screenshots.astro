---
const screens = [
  {
    title: 'Panel de control',
    desc: 'Estado de proyectos, actividad reciente y prioridades del día.',
    meta: ['Obras activas', 'Documentos', 'Pendientes'],
  },
  {
    title: 'Presupuesto modular',
    desc: 'Partidas, materiales y vista de documento en una misma pantalla.',
    meta: ['Partidas', 'Margen', 'PDF'],
  },
  {
    title: 'Trazabilidad documental',
    desc: 'Cada contrato, pedido y factura proforma queda vinculado al proyecto.',
    meta: ['Contrato', 'Pedido', 'Proforma'],
  },
];
---

<section class="py-24 lg:py-32 bg-surface-alt">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16 fade-up">
      <span class="text-accent font-semibold text-sm uppercase tracking-wider">La plataforma</span>
      <h2 class="font-heading font-bold text-3xl sm:text-4xl tracking-tight text-text-primary mt-3 mb-4">
        Una interfaz pensada para profesionales
      </h2>
      <p class="text-text-secondary text-lg">
        Mockups abstractos de producto, sin datos reales ni capturas publicadas, para mostrar la lógica de trabajo.
      </p>
    </div>

    <!-- Product mockups -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 stagger-children">
      {screens.map((screen) => (
        <div class="fade-up">
          <article class="h-full bg-surface rounded-2xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300">
            <div class="aspect-[4/3] bg-surface-alt p-4">
              <div class="h-full rounded-xl bg-surface border border-gray-100 shadow-sm overflow-hidden" aria-hidden="true">
                <div class="flex items-center justify-between border-b border-gray-100 px-4 py-3">
                  <div class="flex items-center gap-2">
                    <span class="w-2.5 h-2.5 rounded-full bg-accent/60"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-accent/30"></span>
                    <span class="w-2.5 h-2.5 rounded-full bg-gray-200"></span>
                  </div>
                  <div class="h-2 w-16 rounded-full bg-gray-100"></div>
                </div>
                <div class="grid grid-cols-[0.8fr_1.2fr] h-[calc(100%-45px)]">
                  <div class="border-r border-gray-100 p-3 space-y-3">
                    <div class="h-3 w-16 rounded-full bg-accent/20"></div>
                    <div class="space-y-2">
                      <div class="h-8 rounded-lg bg-accent/10 border border-accent/10"></div>
                      <div class="h-8 rounded-lg bg-gray-100"></div>
                      <div class="h-8 rounded-lg bg-gray-100"></div>
                    </div>
                  </div>
                  <div class="p-3 space-y-3">
                    <div class="grid grid-cols-3 gap-2">
                      {screen.meta.map((item) => (
                        <div class="rounded-lg border border-gray-100 bg-surface-alt p-2">
                          <div class="h-2 w-10 rounded-full bg-accent/20 mb-2"></div>
                          <div class="h-2 w-full rounded-full bg-gray-200"></div>
                          <span class="sr-only">{item}</span>
                        </div>
                      ))}
                    </div>
                    <div class="rounded-xl border border-gray-100 p-3 space-y-2">
                      <div class="h-2.5 w-2/3 rounded-full bg-text-primary/10"></div>
                      <div class="h-2 w-full rounded-full bg-gray-100"></div>
                      <div class="h-2 w-5/6 rounded-full bg-gray-100"></div>
                      <div class="h-8 rounded-lg bg-accent/10 mt-3"></div>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                      <div class="h-10 rounded-lg bg-gray-100"></div>
                      <div class="h-10 rounded-lg bg-gray-100"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-heading font-semibold text-text-primary mb-1">{screen.title}</h3>
              <p class="text-text-secondary text-sm">{screen.desc}</p>
            </div>
          </article>
        </div>
      ))}
    </div>

    <!-- Note about screen size -->
    <div class="mt-10 text-center fade-up">
      <div class="inline-flex items-center gap-2 bg-accent/5 border border-accent/20 rounded-full px-5 py-2">
        <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="text-sm text-text-secondary">Interfaz pensada para oficina, con más espacio y contexto en pantallas amplias</span>
      </div>
    </div>
  </div>
</section>
