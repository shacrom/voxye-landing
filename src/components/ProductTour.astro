---
import { Image } from 'astro:assets';
import imagenPresupuesto from '../assets/images/imagen_presupuesto.png';
import imagenContrato from '../assets/images/imagen_contrato.png';
import imagenPedidos from '../assets/images/imagen_pedidos.png';
import imagenIncidencias from '../assets/images/imagen_incidencias.png';
import imagenProforma from '../assets/images/imagen_proforma.png';

// Quick-look tour of the product flow: presupuesto -> contrato -> pedido -> incidencia -> proforma.
// Each step carries the doc code shown across the site (see Workflow.astro tags) so the tour
// reads as a continuation of the same document trail, not a separate feature list.
//
// To enable a step, drop the screenshot into src/assets/images/, import it at the top of this
// file, and set it as the `image` field on the matching step object below. That's the entire
// upload contract — no other code changes needed. Steps with image: null render as muted,
// non-interactive "Próximamente" entries until a screenshot is added.
const steps = [
  {
    code: 'PAS-01',
    title: 'Presupuesto',
    description: 'Arma el presupuesto en el editor modular y comparte la vista previa en PDF con el cliente en el momento.',
    image: imagenPresupuesto,
  },
  {
    code: 'PAS-02',
    title: 'Contrato',
    description: 'Con un clic, el presupuesto aceptado se convierte en contrato. El contenido queda congelado y trazado al original.',
    image: imagenContrato,
  },
  {
    code: 'PAS-03',
    title: 'Pedido a proveedor',
    description: 'Genera pedidos a proveedores directamente desde las partidas del contrato, sin volver a teclear nada.',
    image: imagenPedidos,
  },
  {
    code: 'PAS-04',
    title: 'Incidencias',
    description: 'Registra incidencias de obra vinculadas al contrato y haz seguimiento hasta que queden resueltas.',
    image: imagenIncidencias,
  },
  {
    code: 'PAS-05',
    title: 'Factura proforma',
    description: 'Cierra el proyecto con la proforma final, con los anticipos ya cobrados deducidos automáticamente.',
    image: imagenProforma,
  },
];

const firstEnabledIndex = steps.findIndex((step) => step.image !== null);
---

<section id="demo" class="py-24 lg:py-32 bg-surface fade-up">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-3xl mb-16">
      <p class="doc-label text-accent mb-4">Voxye en acción</p>
      <h2 class="font-display font-bold text-3xl sm:text-4xl lg:text-[2.75rem] text-text-primary mb-4 leading-tight">
        Un recorrido rápido por el flujo
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl">
        Cada paso del expediente tiene su pantalla. Elige uno para ver cómo se ve dentro de Voxye.
      </p>
    </div>

    <div class="grid lg:grid-cols-[360px_1fr] gap-10 lg:gap-14">
      <!-- Step list -->
      <div class="relative">
        <!-- Traceability thread: vertical fill on desktop, matches the motif used in Workflow.astro -->
        <div class="tour-thread hidden lg:block absolute top-2 bottom-2 left-[1.15rem] w-px bg-line" aria-hidden="true">
          <div class="tour-thread-fill absolute top-0 left-0 w-full bg-accent origin-top"></div>
        </div>

        <div
          id="tour-step-list"
          role="tablist"
          aria-label="Pasos del recorrido de producto"
          aria-orientation="vertical"
          class="flex lg:flex-col gap-3 overflow-x-auto lg:overflow-visible pb-2 lg:pb-0 lg:pl-10 -mx-4 px-4 sm:mx-0 sm:px-0"
        >
          {steps.map((step, i) => (
            step.image ? (
              <button
                type="button"
                role="tab"
                id={`tour-tab-${i}`}
                aria-controls="tour-panel"
                aria-selected={i === firstEnabledIndex ? 'true' : 'false'}
                tabindex={i === firstEnabledIndex ? 0 : -1}
                data-step-index={i}
                data-step-desc={step.description}
                data-tour-tab
                class="tour-step shrink-0 lg:shrink text-left w-56 lg:w-full doc-card p-4 transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2"
              >
                <span class="doc-label text-accent block mb-1">{step.code}</span>
                <span class="font-display font-semibold text-text-primary block">{step.title}</span>
              </button>
            ) : (
              <div
                aria-disabled="true"
                tabindex={-1}
                class="tour-step tour-step-disabled shrink-0 lg:shrink text-left w-56 lg:w-full doc-card p-4 opacity-50 cursor-not-allowed select-none"
              >
                <span class="doc-label text-text-secondary block mb-1">{step.code}</span>
                <span class="font-display font-semibold text-text-primary block">{step.title}</span>
                <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-secondary mt-2 inline-block">
                  Próximamente
                </span>
              </div>
            )
          ))}
        </div>
      </div>

      <!-- Screenshot panel -->
      <div>
        <div
          id="tour-panel"
          role="tabpanel"
          aria-labelledby={`tour-tab-${firstEnabledIndex}`}
          class="doc-card overflow-hidden"
        >
          <!-- Header strip: doc code of the active step -->
          <div class="flex items-center justify-between px-5 py-3 border-b border-line bg-surface-alt">
            <span id="tour-panel-code" class="doc-label text-accent">{steps[firstEnabledIndex].code}</span>
            <span class="font-mono text-[0.65rem] uppercase tracking-wider text-text-secondary">Voxye</span>
          </div>

          <!-- Fixed aspect-ratio container: no layout shift when swapping images -->
          <div class="relative aspect-[1896/939] bg-surface-alt" id="tour-image-wrap">
            {steps.map((step, i) => (
              step.image && (
                <Image
                  src={step.image}
                  alt={`Pantalla de ${step.title} en Voxye`}
                  widths={[640, 960, 1280, 1600, 1896]}
                  sizes="(min-width: 1024px) 720px, 100vw"
                  quality={90}
                  loading={i === firstEnabledIndex ? 'eager' : 'lazy'}
                  data-step-index={i}
                  data-tour-image
                  class="tour-image absolute inset-0 w-full h-full object-cover"
                  style={i === firstEnabledIndex ? 'opacity:1' : 'opacity:0'}
                />
              )
            ))}
          </div>
        </div>

        <!-- Caption -->
        <div class="mt-6">
          <h3 id="tour-title" class="font-display font-semibold text-xl text-text-primary mb-2">
            {steps[firstEnabledIndex].title}
          </h3>
          <p id="tour-desc" class="text-text-secondary leading-relaxed">
            {steps[firstEnabledIndex].description}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tour-thread-fill {
    height: 0%;
    transition: height 0.2s ease-out;
  }

  .tour-step[aria-selected='true'] {
    border-color: var(--color-accent);
  }

  .tour-image {
    transition: opacity 0.18s ease-in-out;
  }

  @media (prefers-reduced-motion: reduce) {
    .tour-thread-fill {
      transition: none;
    }

    .tour-image {
      transition: none;
    }
  }
</style>

<script>
  // Quick-look product tour: swaps screenshot + caption between enabled steps.
  // Disabled ("Próximamente") steps are inert — no click handler, not in the tab order.
  function initProductTour() {
    const list = document.getElementById('tour-step-list');
    if (!list) return;

    const tabs = Array.from(list.querySelectorAll<HTMLButtonElement>('[data-tour-tab]'));
    if (tabs.length === 0) return;

    const images = Array.from(document.querySelectorAll<HTMLImageElement>('[data-tour-image]'));
    const panelCode = document.getElementById('tour-panel-code');
    const titleEl = document.getElementById('tour-title');
    const descEl = document.getElementById('tour-desc');
    const threadFill = document.querySelector<HTMLElement>('.tour-thread-fill');

    const totalSteps = list.children.length;

    const stepData = tabs.map((tab) => ({
      index: Number(tab.dataset.stepIndex),
      code: tab.querySelector('.doc-label')?.textContent?.trim() ?? '',
      title: tab.querySelector('.font-display')?.textContent?.trim() ?? '',
    }));

    // Full step descriptions aren't in the DOM for inactive steps, so read them back from
    // a small lookup built from the same source data rendered server-side via data attributes.
    const descriptions = new Map<number, string>();
    tabs.forEach((tab) => {
      const idx = Number(tab.dataset.stepIndex);
      const desc = tab.dataset.stepDesc;
      if (desc) descriptions.set(idx, desc);
    });

    function activate(index: number) {
      tabs.forEach((tab) => {
        const isActive = Number(tab.dataset.stepIndex) === index;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.tabIndex = isActive ? 0 : -1;
      });

      images.forEach((img) => {
        const isActive = Number(img.dataset.stepIndex) === index;
        img.style.opacity = isActive ? '1' : '0';
        if (isActive) img.loading = 'eager';
      });

      const active = stepData.find((s) => s.index === index);
      if (active) {
        if (panelCode) panelCode.textContent = active.code;
        if (titleEl) titleEl.textContent = active.title;
        const desc = descriptions.get(index);
        if (descEl && desc) descEl.textContent = desc;
      }

      if (threadFill) {
        const progress = totalSteps > 1 ? index / (totalSteps - 1) : 0;
        threadFill.style.height = `${progress * 100}%`;
      }
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activate(Number(tab.dataset.stepIndex)));
    });

    list.addEventListener('keydown', (event) => {
      const key = event.key;
      if (!['ArrowDown', 'ArrowRight', 'ArrowUp', 'ArrowLeft'].includes(key)) return;

      const currentIndex = tabs.findIndex((tab) => tab.getAttribute('aria-selected') === 'true');
      if (currentIndex === -1) return;

      event.preventDefault();
      const forward = key === 'ArrowDown' || key === 'ArrowRight';
      const nextIndex = forward
        ? (currentIndex + 1) % tabs.length
        : (currentIndex - 1 + tabs.length) % tabs.length;

      const nextTab = tabs[nextIndex];
      activate(Number(nextTab.dataset.stepIndex));
      nextTab.focus();
    });

    // Initialize thread position for the pre-selected step (server-rendered default).
    const initialIndex = Number(tabs.find((t) => t.getAttribute('aria-selected') === 'true')?.dataset.stepIndex ?? 0);
    if (threadFill) {
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReducedMotion) {
        const progress = totalSteps > 1 ? initialIndex / (totalSteps - 1) : 0;
        threadFill.style.height = `${progress * 100}%`;
      } else {
        requestAnimationFrame(() => {
          const progress = totalSteps > 1 ? initialIndex / (totalSteps - 1) : 0;
          threadFill.style.height = `${progress * 100}%`;
        });
      }
    }
  }

  initProductTour();
</script>
